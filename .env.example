PROJECT_NAME=Oficina Mecânica

# Supabase Session Pooler (IPv4 friendly on free plans)
# Example:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional (for Supabase/Render usually require)
DB_SSLMODE=require

# Security
SECRET_KEY=change-this-to-a-strong-random-secret
SECRET_ALGORITHM=HS256
RESET_TOKEN_EXPIRE_MINUTES=30

# Default admin bootstrap (first startup)
DEFAULT_ADMIN_NAME=Administrador
DEFAULT_ADMIN_EMAIL=admin@oficina.local
DEFAULT_ADMIN_PASSWORD=change-this-password
SHOW_DEFAULT_ADMIN_HINT=false
